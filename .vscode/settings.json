{
  "css.lint.unknownAtRules": "ignore",
  // "typescript.experimental.useTsgo": true,
  "typescript.preferences.includePackageJsonAutoImports": "on",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.useLabelDetailsInCompletionEntries": true,
  "typescript.suggest.completeFunctionCalls": true,
  "typescript.suggest.completeJSDocs": true,
  "typescript.preferences.quoteStyle": "single",
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/.vscode/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/bindings": true,
    "**/src/assets": true,
    "**/src/test": true,
    "**/src/test-results": true,
    "**/src/test-report": true,
    "**/src/test-trace": true,
  },
  "typescript.experimental.useTsgo": true,
  "git.enabled": false,
  "terminal.integrated.profiles.osx": {
    "bun dev": {
      "path": "/opt/homebrew/bin/fish",
      "args": ["-l", "-C", "cd ${workspaceFolder}/frontend; bun dev"],
      "icon": "cursor",
      "color": "terminal.ansiBlack"
    },
    "codex": {
      "path": "/opt/homebrew/bin/fish",
      "args": ["-l", "-C", "cd ${workspaceFolder}; codex"],
      "icon": "cursor-bigger",
      "color": "terminal.ansiWhite"
    },
    "claude": {
      "path": "/opt/homebrew/bin/fish",
      "args": ["-l", "-C", "cd ${workspaceFolder}; claude"],
      "icon": "asterisk",
      "color": "terminal.ansiRed"
    },
    "jj": {
      "path": "/opt/homebrew/bin/fish",
      "args": ["-l", "-C", "cd ${workspaceFolder}; jj"],
      "icon": "git-branch",
      "color": "terminal.ansiGreen"
    }
  }
}
