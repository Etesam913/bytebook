{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --minify false --mode development",
    "build:prod": "vite build --mode production",
    "build:analyze": "VITE_ANALYZE=true vite build --mode production",
    "build:ci": "vite build --mode production",
    "preview": "vite preview",
    "test:unit": "bun test",
    "test:unit:ui": "bun test --watch",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui -c tests/e2e/playwright.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --fix .",
    "lint:check": "bun run eslint .",
    "tsgo": "tsgo",
    "format:lint:tsgo": "bun run format:check && bun run lint:check && bun run tsgo",
    "size": "size-limit",
    "knip": "bunx knip",
    "knip:ci": "bunx knip --reporter github-actions --reporter compact"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@floating-ui/react": "^0.27.18",
    "@lexical/list": "^0.41.0",
    "@lexical/markdown": "^0.41.0",
    "@lexical/react": "^0.41.0",
    "@lexical/rich-text": "^0.41.0",
    "@lexical/selection": "^0.41.0",
    "@lexical/table": "^0.41.0",
    "@lexical/utils": "^0.41.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@uiw/codemirror-theme-vscode": "^4.25.4",
    "@uiw/react-codemirror": "^4.25.4",
    "@vitejs/plugin-react": "^5.1.4",
    "jotai": "^2.18.0",
    "katex": "^0.16.28",
    "lexical": "^0.41.0",
    "motion": "^12.34.3",
    "react-error-boundary": "^6.1.1",
    "react-use-measure": "^2.1.7",
    "react-virtuoso": "^4.18.1",
    "sonner": "^2.0.7",
    "wouter": "^3.9.0"
  },
  "overrides": {
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@size-limit/preset-app": "^12.0.0",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.9",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260221.1",
    "@wailsio/runtime": "3.0.0-alpha.66",
    "babel-plugin-react-compiler": "1.0.0",
    "bun-types": "latest",
    "clsx": "^2.1.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "knip": "^5.85.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-plugin-visualizer": "^6.0.8",
    "size-limit": "^12.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "npm:rolldown-vite@latest"
  }
}
